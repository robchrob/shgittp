#!/usr/bin/env bash

# shgittp - Portable Dotfiles Bootstrapper
# Version: 0.4.11
# License: MIT

set -euo pipefail
CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/shgittp/config"
DEF_BRANCH=develop; DEF_DIR=.dot; DEF_BAK=.dot-backup; DEF_TREE=""

usage() { cat <<'EOF'; exit; }
shgittp v0.4.11
Usage: shgittp [options] [user@]host [ssh-opts...]
Options:
  -r, --repo URL      Git repository URL
  -b, --branch NAME   Git branch (default: develop)
  -w, --work-tree DIR Target directory (default: $HOME)
  -x, --run COMMAND   Post-run command
  -A, --agent         Enable SSH agent forwarding
  -i, --interactive   Stay in interactive shell after installation
  -d, --dry-run       Show payload without executing
  --clone-full        Disable shallow clone optimization
  -v, --version       Show version
  -h, --help          Show this help
EOF

log() { echo "== $*"; }
err() { echo "!! $*" >&2; exit 1; }

CLI_REPO=""; CLI_BRANCH=""; CLI_TREE=""; CLI_RUN=""
AGENT=0; INTERACTIVE=0; DRY=0; CLONE_FULL=0; TARGET=""; SSH_ARGS=()

while [[ $# -gt 0 ]]; do
  case $1 in
    -r|--repo) CLI_REPO=$2; shift ;;
    -b|--branch) CLI_BRANCH=$2; shift ;;
    -w|--work-tree) CLI_TREE=$2; shift ;;
    -x|--run) CLI_RUN=$2; shift ;;
    -A|--agent) AGENT=1 ;;
    -i|--interactive) INTERACTIVE=1 ;;
    -d|--dry-run) DRY=1 ;;
    --clone-full) CLONE_FULL=1 ;;
    -v|--version) echo "shgittp v0.4.11"; exit ;;
    -h|--help) usage ;;
    --) shift; SSH_ARGS+=("$@"); break ;;
    -*) SSH_ARGS+=("$1") ;;
    *) [[ -z $TARGET ]] && TARGET=$1 || SSH_ARGS+=("$1") ;;
  esac
  shift
done

[[ $TARGET ]] || usage

HOST=${TARGET##*@}
declare -A CFG=()

[[ -f $CONFIG ]] && {
  SECT="global"
  while read -r L; do
    [[ $L =~ ^[[:space:]]*(#|$) ]] && continue
    [[ $L =~ ^\[(.+)\] ]] && { SECT=${BASH_REMATCH[1]}; continue; }
    [[ $SECT == global || $SECT == $HOST || $SECT == $TARGET ]] || continue

    [[ $L =~ ^(REPO_URL|BRANCH|DOTFILES_DIR|BACKUP_DIR_PREFIX|TARGET_WORK_TREE|USER)(_([^=]+))?=\"?([^\"]*) ]] || continue

    K=${BASH_REMATCH[1]}; S=${BASH_REMATCH[3]:-default}; V=${BASH_REMATCH[4]}
    case $K in
      REPO_URL) CFG[$S,URL]=$V ;;
      BRANCH)   CFG[$S,BRANCH]=$V ;;
      DOTFILES_DIR) CFG[$S,DIR]=$V ;;
      BACKUP_DIR_PREFIX) CFG[$S,BACKUP]=$V ;;
      TARGET_WORK_TREE) CFG[$S,TREE]=$V ;;
      USER) CFG[$S,USER]=$V ;;
    esac
  done < "$CONFIG"
}

CFG[default,URL]=${CLI_REPO:-${CFG[default,URL]:-}}
CFG[default,BRANCH]=${CLI_BRANCH:-${CFG[default,BRANCH]:-$DEF_BRANCH}}
CFG[default,TREE]=${CLI_TREE:-${CFG[default,TREE]:-$DEF_TREE}}

SETS=($(printf '%s\n' "${!CFG[@]}" | grep ',URL$' | cut -d, -f1 | sort -u))

(( ${#SETS[@]} )) || err "No repositories configured"
for S in "${SETS[@]}"; do
  U=${CFG[$S,URL]}
  [[ $U ]] || err "Set '$S' missing URL"
  [[ $U == git@*:*/* && $AGENT -eq 0 ]] && err "SSH URL requires -A"
done

if ((DRY)); then
  for S in "${SETS[@]}"; do
    AUTH=${CFG[$S,USER]:-}
    STATUS=process
    [[ $AUTH && $TARGET == *@* && $AUTH != ${TARGET%%@*} ]] && STATUS="skip (user)"
    echo "[$S] ${CFG[$S,URL]:-<none>} -> $STATUS"
  done
  exit 0
fi

declare -A USERS=()
for S in "${SETS[@]}"; do
  U=${CFG[$S,USER]:-} && [[ $U ]] && USERS[$U]=1
done

TARGETS=()
if [[ $TARGET == *@* ]]; then
  TARGETS+=("$TARGET")
elif (( ${#USERS[@]} )); then
  SORTED_USERS=($(echo "${!USERS[@]}" | tr ' ' '\n' | sort))
  for U in "${SORTED_USERS[@]}"; do TARGETS+=("$U@$TARGET"); done
else
  TARGETS+=("$TARGET")
fi

payload() {
  local USER=$1
  cat <<SH
#!/bin/sh
set -eu
export AGENT=$AGENT POST_RUN=$(printf '%q' "${CLI_RUN:-}") INTERACTIVE=$INTERACTIVE
export TARGET_WORK_TREE=$(printf '%q' "${CFG[default,TREE]:-$DEF_TREE}")
export CLONE_FULL=$CLONE_FULL

# Disable host key checking and suppress warnings for automation
export GIT_SSH_COMMAND="ssh -F /dev/null -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"

command -v git >/dev/null || { echo "error: git not found" >&2; exit 1; }

run() {
  local SUF=\$1 URL=\$2 BR=\$3 DIR=\$4 BACK=\$5 TREE=\$6
  local GITDIR=\$HOME/\$DIR; TREE=\${TREE:-\$HOME}

  mkdir -p "\$TREE" 2>/dev/null || { echo "error: cannot create \$TREE" >&2; exit 1; }

  git() { command git --git-dir="\$GITDIR" --work-tree="\$TREE" "\$@"; }

  if [ -d "\$GITDIR" ]; then
    printf "[\$SUF] updating & checkout... "
    git fetch -q origin 2>/dev/null || { echo "failed" >&2; exit 1; }
  else
    printf "[\$SUF] cloning & checkout... "
    if [ "\$CLONE_FULL" = "1" ]; then
      command git clone --bare -q "\$URL" "\$GITDIR" 2>/dev/null || { echo "failed" >&2; exit 1; }
    else
      # Optimized shallow clone: faster, smaller
      command git clone --bare --depth 1 --single-branch --branch "\$BR" -q "\$URL" "\$GITDIR" 2>/dev/null || {
        echo "failed" >&2; exit 1;
      }
    fi
  fi

  git config status.showUntrackedFiles no

  if git checkout -q "\$BR" 2>/dev/null; then
    echo "ok"
  else
    echo "conflict"
    printf "[\$SUF] backing up conflicting files... "
    BAK=\$HOME/\${BACK}-\${BR}-\$(date +%Y%m%d-%H%M%S)
    mkdir -p "\$BAK"
    git ls-tree -rz --name-only "\$BR" 2>/dev/null | xargs -0 -I{} sh -c '
      [ -f "'"\$TREE"'/{}" ] || exit 0
      mkdir -p "'"\$BAK"'/\$(dirname "{}")" 2>/dev/null
      mv "'"\$TREE"'/{}" "'"\$BAK"'/{}" 2>/dev/null || true
    '
    git checkout -fq "\$BR" 2>/dev/null || { echo "failed" >&2; exit 1; }
    echo "ok (saved to \$BAK)"
  fi

  ALIAS=\${SUF,,}
  [ "\$SUF" = default ] && ALIAS=cfg || ALIAS=cfg-\$ALIAS
  echo "[\$SUF] alias \$ALIAS='git --git-dir=\$GITDIR --work-tree=\$TREE'"
}
SH

  # Output connection header with first repo's directory
  FIRST_DIR=""
  for S in "${SETS[@]}"; do
    AUTH=${CFG[$S,USER]:-}
    [[ $AUTH && $AUTH != $USER ]] && continue
    FIRST_DIR=${CFG[$S,DIR]:-$DEF_DIR}
    break
  done

  echo "echo \"== Connected to \$(whoami)@\$(hostname) (dir \\\$HOME/$FIRST_DIR)\""

  for S in "${SETS[@]}"; do
    AUTH=${CFG[$S,USER]:-}
    [[ $AUTH && $AUTH != $USER ]] && continue

    printf "run %q %q %q %q %q %q\n" \
      "$S" \
      "${CFG[$S,URL]}" \
      "${CFG[$S,BRANCH]:-${CFG[default,BRANCH]}}" \
      "${CFG[$S,DIR]:-$DEF_DIR}" \
      "${CFG[$S,BACKUP]:-$DEF_BAK}" \
      "${CFG[$S,TREE]:-$DEF_TREE}"
  done

  cat <<'SH'

[ -n "$POST_RUN" ] && {
  printf "post-run: %s... " "$POST_RUN"
  (cd "$TARGET_WORK_TREE" && bash -c "$POST_RUN") 2>/dev/null || { echo "failed" >&2; exit 1; }
  echo "ok"
}

echo "==> complete"
[ "$INTERACTIVE" = 1 ] && exec bash -l
exit 0
SH
}

SSH=(ssh); ((AGENT)) && SSH+=(-A); SSH+=("${SSH_ARGS[@]}")

for T in "${TARGETS[@]}"; do
  USER=${T%%@*}; [[ $USER == $T ]] && USER=""
  payload "$USER" | "${SSH[@]}" "$T" bash -s || err "$T failed"
done
