#!/usr/bin/env bash
# shgittp - Portable Dotfiles Bootstrapper
# License: MIT
set -euo pipefail

# --- 1. Setup & Defaults ---
VER="0.4.12"
ver()   { echo "shgittp v$VER"; exit 0; }
die()   { echo -e "\033[31m!! $*\033[0m" >&2; exit 1; }
usage() { echo -e "shgittp v$VER\n\t[-r URL] [-b BRANCH] [-w DIR] [-x CMD] [-Aid] [--clone-full] [user@]host"; exit 0; }

declare -A CFG USERS SETS DEF
DEF=([URL]="" [BRANCH]="develop" [DIR]=".dot" [BACKUP]=".dot-backup" [TREE]="" [RUN]="")

CFG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/shgittp/config"
ARGS=() TARGET="" AGENT=0 INTERACTIVE=0 DRY=0 FULL=0

# --- 2. CLI Parsing ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    -r|--repo)      CFG[default:URL]="$2"; SETS[default]=1; shift 2 ;;
    -b|--branch)    CFG[default:BRANCH]="$2"; shift 2 ;;
    -w|--work-tree) CFG[default:TREE]="$2"; shift 2 ;;
    -x|--run)       CFG[default:RUN]="$2"; shift 2 ;;
    -A|--agent)     AGENT=1; shift ;;
    -i|--interactive) INTERACTIVE=1; shift ;;
    -d|--dry-run)   DRY=1; shift ;;
    --clone-full)   FULL=1; shift ;;
    -v|--version)   ver ;;
    -h|--help)      usage ;;
    --)             shift; ARGS+=("$@"); break ;;
    -*)             ARGS+=("$1"); shift ;;
    *)              [[ -z $TARGET ]] && TARGET="$1" || ARGS+=("$1"); shift ;;
  esac
done
[[ -n $TARGET ]] || usage

# --- 3. Config Parsing ---
HOST="${TARGET##*@}"
if [[ -f $CFG_FILE ]]; then
  SECTION="default"
  while IFS= read -r line || [[ -n $line ]]; do
    line="${line#"${line%%[![:space:]]*}"}"  # ltrim
    line="${line%"${line##*[![:space:]]}"}"  # rtrim
    [[ -z $line || $line =~ ^# ]] && continue
    if [[ $line =~ ^\[(.+)\]$ ]]; then
      SECTION="${BASH_REMATCH[1]}"
      continue
    fi
    [[ $SECTION =~ ^(global|$HOST|$TARGET|default)$ ]] || continue
    if [[ $line =~ ^([A-Z_][A-Z0-9_]*)=(.*)$ ]]; then
      KEY="${BASH_REMATCH[1]}"
      VAL="${BASH_REMATCH[2]}"
      [[ $VAL =~ ^\"(.*)\"$ || $VAL =~ ^\'(.*)\'$ ]] && VAL="${BASH_REMATCH[1]}"
      SUFFIX="default"
      if [[ $KEY =~ ^(.+)_([A-Z][A-Z0-9]*)$ ]]; then
        case "${BASH_REMATCH[1]}" in
          REPO_URL|BRANCH|DOTFILES_DIR|BACKUP_DIR_PREFIX|TARGET_WORK_TREE|USER|RUN_COMMAND)
            BASE="${BASH_REMATCH[1]}"
            SUFFIX="${BASH_REMATCH[2],,}"  # lowercase
            ;;
          *) BASE="$KEY" ;;
        esac
      else
        BASE="$KEY"
      fi
      case "$BASE" in
        REPO_URL)          IKEY="URL"; SETS[$SUFFIX]=1 ;;
        DOTFILES_DIR)      IKEY="DIR" ;;
        BACKUP_DIR_PREFIX) IKEY="BACKUP" ;;
        TARGET_WORK_TREE)  IKEY="TREE" ;;
        RUN_COMMAND)       IKEY="RUN" ;;
        BRANCH)            IKEY="BRANCH" ;;
        USER)              IKEY="USER" ;;
        *)                 continue ;;
      esac

      CFG[$SUFFIX:$IKEY]="$VAL"
    fi
  done < "$CFG_FILE"
fi

IFS=$'\n' SORTED_KEYS=($(printf "%s\n" "${!SETS[@]}" | sort -V)); unset IFS
(( ${#SORTED_KEYS[@]} )) || die "No repositories configured for target '$HOST'."

# --- 4. Target Resolution ---
T_USER="${TARGET%%@*}"; [[ $T_USER == "$TARGET" ]] && T_USER=""
for S in "${SORTED_KEYS[@]}"; do
  [[ -z ${CFG[$S:URL]:-} ]] && die "Set '$S' missing URL."
  U="${CFG[$S:USER]:-}"; [[ -n $U ]] && USERS[$U]=1
done
DESTS=()
if [[ -n $T_USER ]]; then
  DESTS+=("$TARGET")
elif (( ${#USERS[@]} )); then
  for U in "${!USERS[@]}"; do DESTS+=("$U@$HOST"); done
  for S in "${SORTED_KEYS[@]}"; do [[ -z ${CFG[$S:USER]:-} ]] && { DESTS+=("$TARGET"); break; }; done
else
  DESTS+=("$TARGET")
fi

# --- 5. Helpers ---
get_val() {
  local S=$1 K=$2
  echo "${CFG[$S:$K]:-${CFG[default:$K]:-${DEF[$K]}}}"
}

if ((DRY)); then
  echo ":: Dry Run ::"
  for DST in "${DESTS[@]}"; do
    echo "Target: $DST"
    DU="${DST%%@*}"; [[ $DU == "$DST" ]] && DU=""
    for S in "${SORTED_KEYS[@]}"; do
      SU="${CFG[$S:USER]:-}"
      [[ -n $SU && -n $DU && $SU != "$DU" ]] && continue
      TREE=$(get_val "$S" TREE); [[ -z $TREE ]] && TREE="\$HOME"
      echo "  ➜ [$S] $(get_val "$S" URL) ($(get_val "$S" BRANCH)) -> $TREE"
      echo "     Run: $(get_val "$S" RUN)"
    done
  done
  exit 0
fi

# --- 6. Remote Payload ---
generate_payload() {
  local target_label="$1"
cat <<EOF
set -euo pipefail
export GIT_SSH_COMMAND='ssh -F /dev/null -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR'
setup_repo() {
  local ID="\$1" URL="\$2" BR="\$3" GDIR="\$4" BAK="\$5" TREE="\${6:-\$HOME}" RUN="\$7"
  local GIT_DIR="\$HOME/\$GDIR"
  local ALIAS="cfg"; [[ \$ID != "default" ]] && ALIAS="cfg-\${ID,,}"
  mkdir -p "\$TREE"
  # 1. Fetch
  if [[ -d \$GIT_DIR ]]; then
    git --git-dir="\$GIT_DIR" fetch -q origin
  else
    local ARGS="--bare -b \$BR \$URL \$GIT_DIR"
    [[ $FULL == 0 ]] && ARGS="--depth 1 \$ARGS"
    git clone -q \$ARGS || { echo "[$target_label:\$ID] Clone failed"; exit 1; }
  fi
  # 2. Checkout
  git --git-dir="\$GIT_DIR" config status.showUntrackedFiles no
  if ! git --git-dir="\$GIT_DIR" --work-tree="\$TREE" checkout -q "\$BR" 2>/dev/null; then
    local BAK_PATH="\$HOME/\$BAK-\$BR-\$(date +%s)"
    echo "[$target_label:\$ID] Conflict detected, backing up to \$BAK_PATH"
    mkdir -p "\$BAK_PATH"
    git --git-dir="\$GIT_DIR" --work-tree="\$TREE" ls-tree -rz --name-only "\$BR" | \\
      xargs -0 -I{} sh -c '[[ -e "\$TREE/{}" ]] && { mkdir -p "\$BAK_PATH/\$(dirname "{}")"; mv "\$TREE/{}" "\$BAK_PATH/{}"; }'
    git --git-dir="\$GIT_DIR" --work-tree="\$TREE" checkout -fq "\$BR"
  fi
  echo "[$target_label:\$ID] Sync done: \$URL (\$BR)"
  # 3. Post-Run
  [[ -n \$RUN ]] && { echo "[$target_label:\$ID] Running \"\$RUN\" in \$TREE..."; (cd "\$TREE" && eval "\$RUN") || echo "[$target_label:\$ID] Command failed"; }
  # 4. Alias
  echo "alias \$ALIAS='/usr/bin/git --git-dir=\$GIT_DIR --work-tree=\$TREE'" >> "\$HOME/.shgittp_aliases"
}
rm -f "\$HOME/.shgittp_aliases"
EOF
}

# --- 7. Main Execution ---
SSH_OPTS=(-o ForwardAgent=$([[ $AGENT == 1 ]] && echo yes || echo no) "${ARGS[@]}")
PIDS=()

for DST in "${DESTS[@]}"; do
  DU="${DST%%@*}"; [[ $DU == "$DST" ]] && DU=""
  (
    {
      generate_payload "$HOST"
      for S in "${SORTED_KEYS[@]}"; do
        SU="${CFG[$S:USER]:-}"
        [[ -n $SU && -n $DU && $SU != "$DU" ]] && continue

        printf 'setup_repo %q %q %q %q %q %q %q\n' \
          "$S" "$(get_val "$S" URL)" "$(get_val "$S" BRANCH)" \
          "$(get_val "$S" DIR)" "$(get_val "$S" BACKUP)" \
          "$(get_val "$S" TREE)" "$(get_val "$S" RUN)"
      done
      echo 'echo ""'
      echo '[[ -f $HOME/.shgittp_aliases ]] && { echo "Git aliases:"; cat "$HOME/.shgittp_aliases"; rm "$HOME/.shgittp_aliases"; }'
      [[ $INTERACTIVE == 1 ]] && echo 'exec $SHELL -l' || echo 'exit 0'
    } | ssh "${SSH_OPTS[@]}" "$DST" bash -s
  ) & PIDS+=($!)
done

RET=0; for P in "${PIDS[@]}"; do wait "$P" || RET=1; done
exit $RET
