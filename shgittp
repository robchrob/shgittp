#!/bin/sh

set -eu

VER="0.4.15"

die() { printf '\033[31m!! %s\033[0m\n' "$*" >&2; exit 1; }
usage() { printf 'shgittp v%s\n\t[-c FILE] [-r URL] [-b BRANCH] [-w DIR] [-d DIR] [-x CMD] [-i] [--dry-run] [--full-clone] [user@]host\n' "$VER"; exit 0; }

quote() { printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"; }

# Configuration Defaults
CLI_REPO_URL="" CLI_BRANCH="" CLI_DIR="" CLI_TREE="" CLI_RUN=""
DEFAULT_CFG="${XDG_CONFIG_HOME:-$HOME/.config}/shgittp/config"
CFG_FILE="$DEFAULT_CFG"
CUSTOM_CFG=0
TARGET="" INTERACTIVE=0 DRY_RUN=0
EXTRA_ARGS=""

# Parse command line
while [ $# -gt 0 ]; do
  case "$1" in
    -c|--config)   CFG_FILE="$2"; CUSTOM_CFG=1; shift 2 ;;
    -r|--repo)     CLI_REPO_URL="$2"; shift 2 ;;
    -b|--branch)   CLI_BRANCH="$2"; shift 2 ;;
    -d|--dotfiles) CLI_DIR="$2"; shift 2 ;;
    -w|--work)     CLI_TREE="$2"; shift 2 ;;
    -x|--run)      CLI_RUN="$2"; shift 2 ;;
    -i)            INTERACTIVE=1; shift ;;
    --dry-run)     DRY_RUN=1; shift ;;
    -v|--version)  printf 'v%s\n' "$VER"; exit 0 ;;
    -h|--help)     usage ;;
    --)            shift; for a in "$@"; do EXTRA_ARGS="$EXTRA_ARGS $(quote "$a")"; done; break ;;
    -*)            die "Unknown option: $1" ;;
    *)             TARGET="$1"; shift; break ;;
  esac
done

[ -z "$TARGET" ] && usage

# Validate config file existence if explicitly passed
if [ "$CUSTOM_CFG" -eq 1 ] && [ ! -f "$CFG_FILE" ]; then
  die "Configuration file not found: $CFG_FILE"
fi

# Parse INI config
HOST="${TARGET##*@}"
IN_HOST_SECTION=0
if [ -f "$CFG_FILE" ]; then
  SECTION="" SUFFIX=""
  while IFS='=' read -r k v || [ -n "$k" ]; do
    case "$k" in ''|'#'*) continue;; esac
    k="${k#"${k%%[! ]*}"}"; k="${k%"${k##*[! ]}"}"

    case "$k" in
      '['*']')
        SECTION="${k#'['}"; SECTION="${SECTION%']'}"
        case "$SECTION" in
          default) SUFFIX="default"; IN_HOST_SECTION=0 ;;
          "$HOST"|"$TARGET") SUFFIX="default"; IN_HOST_SECTION=1 ;;
          *) SUFFIX=""; IN_HOST_SECTION=0 ;;
        esac
        continue ;;
    esac

    [ -z "$SUFFIX" ] && continue

    v="${v#"${v%%[! ]*}"}"; v="${v%"${v##*[! ]}"}"
    v="${v#\"}"; v="${v%\"}"; v="${v#\'}"; v="${v%\'}"

    # Parse key_suffix pattern
    SUF="default" BASE="$k"
    case "$k" in
      *_*)
        STEM="${k%_*}"
        case "$STEM" in
          repo|branch|dir|tree|run|user|REPO_URL|BRANCH|DIR|TREE|RUN|USER)
            BASE="$STEM"
            SUF="${k##*_}"
            SUF=$(printf '%s' "$SUF" | tr '[:upper:]' '[:lower:]')
            ;;
        esac ;;
    esac

    case "$BASE" in
      repo)   KEY=REPO_URL ;;
      branch) KEY=BRANCH ;;
      dir)    KEY=DIR ;;
      tree)   KEY=TREE ;;
      run)    KEY=RUN ;;
      user)   KEY=USER ;;
      REPO_URL|BRANCH|DIR|TREE|RUN|USER) KEY="$BASE" ;;
      *) continue ;;
    esac

    eval "CFG_${SUF}_${KEY}=\$v"
    [ "$IN_HOST_SECTION" -eq 1 ] && eval "JOB_${SUF}=1"
  done < "$CFG_FILE"
fi

# Apply CLI overrides to default job
[ -n "$CLI_REPO_URL" ] && { CFG_default_REPO_URL="$CLI_REPO_URL"; JOB_default=1; }
[ -n "$CLI_BRANCH" ]   && CFG_default_BRANCH="$CLI_BRANCH"
[ -n "$CLI_DIR" ]      && CFG_default_DIR="$CLI_DIR"
[ -n "$CLI_TREE" ]     && CFG_default_TREE="$CLI_TREE"
[ -n "$CLI_RUN" ]      && CFG_default_RUN="$CLI_RUN"

# Get configuration value with fallback chain: job -> default -> hardcoded
get() {
  _suf="$1" _key="$2"
  eval "_val=\${CFG_${_suf}_${_key}-}"
  [ -n "$_val" ] || eval "_val=\${CFG_default_${_key}-}"
  case "$_key" in
    REPO_URL) [ -n "$_val" ] || _val="" ;;
    BRANCH)   [ -n "$_val" ] || _val="main" ;;
    DIR)      [ -n "$_val" ] || _val=".dotfiles" ;;
  esac
  printf '%s' "$_val"
}

# Collect all job suffixes
JOBS=$(set | sed -n 's/^JOB_\([^=]*\)=.*$/\1/p' | sort -V 2>/dev/null || sort)
[ -z "$JOBS" ] && die "No configuration found for '$TARGET' (and no CLI repo provided)"

# Group jobs by connection string (user@host)
BATCH_LIST=""
for J in $JOBS; do
  U=$(get "$J" USER)
  : "${U:=${TARGET%%@*}}"  # Default to target username
  [ "$U" = "$TARGET" ] && U=""  # Handle case where TARGET has no @

  CONN="${U:+$U@}$HOST"
  CONN_VAR=$(printf '%s' "$CONN" | tr '@-' '__')  # Sanitize for variable name

  eval "BATCH_${CONN_VAR}=\"\${BATCH_${CONN_VAR}-}$J \""
  eval "CONN_${CONN_VAR}=\"\$CONN\""

  case " $BATCH_LIST " in
    *" $CONN_VAR "*) ;;  # Already in list
    *) BATCH_LIST="$BATCH_LIST $CONN_VAR" ;;
  esac
done

# Generate remote deployment script
remote_script() {
  _depth="$1"
  cat <<REMOTE
set -e
export GIT_SSH_COMMAND='ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'
deploy() {
  _id="\$1" _url="\$2" _branch="\$3" _dotdir="\$4" _tree="\${5:-\$HOME}" _run="\$6"
  _gitdir="\$HOME/\$_dotdir"
  echo "[\$_id] \$_url (\$_branch) -> \$_gitdir"
  mkdir -p "\$_tree"
  if [ -f "\$_gitdir/config" ]; then
    git --git-dir="\$_gitdir" fetch -q origin "\$_branch"
  else
    git clone -q --bare -b "\$_branch" $_depth "\$_url" "\$_gitdir"
  fi
  git --git-dir="\$_gitdir" config status.showUntrackedFiles no
  if ! git --git-dir="\$_gitdir" --work-tree="\$_tree" checkout -q "\$_branch" 2>/dev/null; then
    _backupdir="\$HOME/\${_dotdir}-backup-\${_id}-\$(date +%s)"
    echo "  Conflict detected, backing up to \$_backupdir"
    git --git-dir="\$_gitdir" --work-tree="\$_tree" ls-tree -rz --name-only "\$_branch" | \\
      xargs -0 -I{} sh -c '_f="{}"; if [ -e "'\"\$_tree\"'/\$_f" ]; then mkdir -p "'\"\$_backupdir\"'/\$(dirname "\$_f")"; mv "'\"\$_tree\"'/\$_f" "'\"\$_backupdir\"'/\$_f"; fi'
    git --git-dir="\$_gitdir" --work-tree="\$_tree" checkout -fq "\$_branch"
  fi
  [ -n "\$_run" ] && { echo "  Running: \$_run"; (cd "\$_tree" && eval "\$_run"); }
}
REMOTE
}

# Check if remote host has git
remote_has_git() {
  _dest="$1"
  eval "ssh $EXTRA_ARGS \"\$_dest\" 'command -v git >/dev/null 2>&1 && echo 1 || echo 0'" 2>/dev/null
}

# Deploy to host without git (bootstrap mode)
deploy_nogit() {
  _dest="$1" _id="$2" _url="$3" _branch="$4" _dotdir="$5" _tree="$6" _run="$7"
  _depth_arg="--depth 1"
  _remote_tree="${_tree:-\$HOME}"

  _tmpdir=$(mktemp -d)
  trap "rm -rf '$_tmpdir'" EXIT

  printf '[%s] %s (%s) -> ~/%s [nogit bootstrap]\n' "$_id" "$_url" "$_branch" "$_dotdir"

  # Clone bare repo locally
  git clone -q --bare -b "$_branch" $_depth_arg "$_url" "$_tmpdir/bare.git" || {
    printf '  \033[31mFailed to clone %s\033[0m\n' "$_url" >&2
    rm -rf "$_tmpdir"
    return 1
  }

  # Checkout worktree locally
  mkdir -p "$_tmpdir/tree"
  git --git-dir="$_tmpdir/bare.git" --work-tree="$_tmpdir/tree" checkout -q "$_branch"
  git --git-dir="$_tmpdir/bare.git" config status.showUntrackedFiles no
  mv "$_tmpdir/bare.git" "$_tmpdir/$_dotdir"

  # Transfer tarball and execute extraction in one step
  (cd "$_tmpdir" && tar -cf - "$_dotdir" tree) | \
    ssh $EXTRA_ARGS "$_dest" "
set -e
cd \$HOME
echo '[$_id] Extracting files to remote'
tar -xf - || { echo 'Extract failed'; exit 1; }

echo '[$_id] Setting up worktree at $_remote_tree'

if [ '$_remote_tree' != '\$HOME' ]; then
  mkdir -p '$_remote_tree'
  cp -a tree/. '$_remote_tree/' 2>/dev/null || true
  rm -rf tree
else
  backupdir=\"\$HOME/${_dotdir}-backup-${_id}-\$(date +%s)\"
  backed_up=0
    for f in tree/.[!.]* tree/*; do
    [ ! -e \"\$f\" ] && continue
    fname=\$(basename \"\$f\")
    [ \"\$fname\" = '$_dotdir' ] && continue
    if [ -e \"\$HOME/\$fname\" ]; then
      [ \"\$backed_up\" -eq 0 ] && mkdir -p \"\$backupdir\"
      mv \"\$HOME/\$fname\" \"\$backupdir/\" 2>/dev/null && { echo '  Backed up: '\$fname; backed_up=1; } || true
    fi
  done
  cp -a tree/. \$HOME/ 2>/dev/null || true
  rm -rf tree
  [ \"\$backed_up\" -eq 1 ] && echo '  Backups in: '\$backupdir
fi

echo '[$_id] Deployment complete'
$([ -n "$_run" ] && printf "echo '  Running: %s'\ncd \"%s\"\n%s" "$_run" "$_remote_tree" "$_run")
" || {
    rm -rf "$_tmpdir"
    return 1
  }

  rm -rf "$_tmpdir"
  trap - EXIT
  return 0
}

# Execute deployments
RET=0
[ "$DRY_RUN" -eq 1 ] && printf '=== DRY RUN MODE ===\n'

PIDS=""
for DEST_VAR in $BATCH_LIST; do
  eval "BATCH_JOBS=\"\${BATCH_${DEST_VAR}-}\""
  eval "DEST=\"\${CONN_${DEST_VAR}}\""

  if [ "$DRY_RUN" -eq 1 ]; then
    printf 'Target: %s\n' "$DEST"
    for J in $BATCH_JOBS; do
      printf '  Job %s: %s (%s)\n' "$J" "$(get "$J" REPO_URL)" "$(get "$J" BRANCH)"
    done
    continue
  fi

  if [ "$(remote_has_git "$DEST")" = "1" ]; then
    DEPTH_VAL="--depth 1"

    # Build and execute deployment script
    SCRIPT=$(remote_script "$DEPTH_VAL")
    for J in $BATCH_JOBS; do
      SCRIPT="$SCRIPT
deploy $(quote "$J") $(quote "$(get "$J" REPO_URL)") $(quote "$(get "$J" BRANCH)") $(quote "$(get "$J" DIR)") $(quote "$(get "$J" TREE)") $(quote "$(get "$J" RUN)")"
    done

    printf '%s\n' "$SCRIPT" | ssh -o ForwardAgent=yes $EXTRA_ARGS "$DEST" sh &
    PIDS="$PIDS $!"
  else
    printf '\033[33m[%s] git not found, using bootstrap mode\033[0m\n' "$DEST"
    for J in $BATCH_JOBS; do
      deploy_nogit "$DEST" "$J" "$(get "$J" REPO_URL)" "$(get "$J" BRANCH)" "$(get "$J" DIR)" "$(get "$J" TREE)" "$(get "$J" RUN)" || RET=1
    done
  fi
done

# Wait for parallel git deployments
for PID in $PIDS; do wait "$PID" || RET=1; done

# Print git aliases on success
if [ "$RET" -eq 0 ] && [ -n "$JOBS" ]; then
  printf '\nGit aliases for configured dotfiles:\n'
  for J in $JOBS; do
    DOTDIR=$(get "$J" DIR)
    TREE=$(get "$J" TREE)
    [ -z "$TREE" ] && TREE="\$HOME"
    ALIAS="cfg"
    [ "$J" != "default" ] && ALIAS="cfg-$J"
    printf '  \033[32m+ alias %s='\''git --git-dir=$HOME/%s --work-tree=%s'\''\033[0m\n' "$ALIAS" "$DOTDIR" "$TREE"
  done
  printf '\n'
fi

# Interactive shell if requested
if [ "$INTERACTIVE" -eq 1 ] && [ "$RET" -eq 0 ]; then
  printf 'Connecting to %s...\n' "$TARGET"
  exec ssh -t -o ForwardAgent=yes $EXTRA_ARGS "$TARGET"
fi

exit "$RET"
