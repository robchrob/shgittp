#!/usr/bin/env bash
# shgittp - Minimal SSH dotfiles bootstrap
set -euo pipefail

VER="0.4.13"
die() { echo -e "\033[31m!! $*\033[0m" >&2; exit 1; }
usage() { echo -e "shgittp v$VER\n\t[-r URL] [-b BRANCH] [-w DIR] [-d DIR] [-x CMD] [-i] [--dry-run] [--full-clone] [user@]host"; exit 0; }

# State
declare -A CFG JOBS BATCHES
declare -A KEYS=([repo]=REPO_URL [branch]=BRANCH [dir]=DIR [tree]=TREE [run]=RUN [user]=USER)
declare -A DEFAULTS=([REPO_URL]="" [BRANCH]="main" [DIR]=".dotfiles" [TREE]="" [RUN]="" [USER]="")

CFG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/shgittp/config"
TARGET="" INTERACTIVE=0 DRY=0 FULL=0
declare -a ARGS=()

# Parse CLI
while [[ $# -gt 0 ]]; do
  case "$1" in
    -r|--repo)     CFG[cli:REPO_URL]="$2"; shift 2 ;;
    -b|--branch)   CFG[cli:BRANCH]="$2"; shift 2 ;;
    -d|--dotfiles) CFG[cli:DIR]="$2"; shift 2 ;;
    -w|--work)     CFG[cli:TREE]="$2"; shift 2 ;;
    -x|--run)      CFG[cli:RUN]="$2"; shift 2 ;;
    -i)            INTERACTIVE=1; shift ;;
    --dry-run)     DRY=1; shift ;;
    --full-clone)  FULL=1; shift ;;
    -v|--version)  echo "v$VER"; exit 0 ;;
    -h|--help)     usage ;;
    --)            shift; ARGS+=("$@"); break ;;
    -*)            ARGS+=("$1"); shift ;;
    *)             TARGET="$1"; shift ;;
  esac
done
[[ -n $TARGET ]] || usage

# Parse INI config
HOST="${TARGET##*@}"
if [[ -f $CFG_FILE ]]; then
  SECTION="default"
  while IFS='=' read -r k v || [[ -n $k ]]; do
    [[ $k =~ ^[[:space:]]*# || -z $k ]] && continue
    if [[ $k =~ ^\[(.+)\]$ ]]; then SECTION="${BASH_REMATCH[1]}"; continue; fi
    [[ $SECTION == "default" || $SECTION == "$HOST" || $SECTION == "$TARGET" ]] || continue
    k="${k%%[[:space:]]*}"; v="${v##[[:space:]]}"; v="${v%%[[:space:]]}"; v="${v%[\"\']}"; v="${v#[\"\']}"
    suffix="default"; base="$k"
    if [[ $k =~ ^(.+)_([a-zA-Z][a-zA-Z0-9_]*)$ ]]; then
      tmp="${BASH_REMATCH[1]}"
      if [[ -n ${KEYS[$tmp]:-} || $tmp =~ ^(REPO_URL|BRANCH|DIR|TREE|RUN|USER)$ ]]; then
        base="$tmp"; suffix="${BASH_REMATCH[2],,}"
      fi
    fi
    full_key="${KEYS[$base]:-$base}"
    if [[ -n ${DEFAULTS[$full_key]:-} || $full_key =~ ^(REPO_URL|BRANCH|DIR|TREE|RUN|USER)$ ]]; then
      CFG["$suffix:$full_key"]="$v"
      [[ $SECTION != "default" ]] && JOBS[$suffix]=1
    fi
  done < "$CFG_FILE"
fi

# CLI overrides defaults
for k in REPO_URL BRANCH DIR TREE RUN USER; do
  [[ -n ${CFG[cli:$k]:-} ]] && CFG[default:$k]="${CFG[cli:$k]}"
done

get() { echo "${CFG[$1:$2]:-${CFG[default:$2]:-${DEFAULTS[$2]}}}"; }
SORTED=($(printf "%s\n" "${!JOBS[@]}" | sort -V))
[[ ${#SORTED[@]} -eq 0 ]] && die "No configuration found for '$TARGET'"
for job in "${SORTED[@]}"; do
  u=$(get "$job" USER)
  [[ -z $u ]] && u="${TARGET%%@*}"
  [[ $u == "$TARGET" ]] && u=""
  BATCHES["${u:+$u@}$HOST"]+="$job "
done

# Generate remote script
remote_script() {
  local depth="--depth 1"; ((FULL)) && depth=""
  cat <<REMOTE
set -e
export GIT_SSH_COMMAND='ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'
deploy() {
  id="\$1" url="\$2" branch="\$3" dotdir="\$4" tree="\${5:-\$HOME}" run="\$6"
  gitdir="\$HOME/\$dotdir"
  echo "[\$id] \$url (\$branch) -> \$gitdir"
  mkdir -p "\$tree"
  if [ -d "\$gitdir/config" ]; then
    git --git-dir="\$gitdir" fetch -q origin "\$branch"
  else
    git clone -q --bare -b "\$branch" $depth "\$url" "\$gitdir"
  fi
  git --git-dir="\$gitdir" config status.showUntrackedFiles no
  if ! git --git-dir="\$gitdir" --work-tree="\$tree" checkout -q "\$branch" 2>/dev/null; then
    backupdir="\$HOME/\${dotdir}-backup-\$id-\$(date +%s)"
    echo "  Conflict detected, backing up to \$backupdir"
    git --git-dir="\$gitdir" --work-tree="\$tree" ls-tree -rz --name-only "\$branch" | \\
      xargs -0 -I{} sh -c '[ -e "\$tree/{}" ] && { mkdir -p "\$backupdir/\$(dirname "{}")"; mv "\$tree/{}" "\$backupdir/{}"; }'
    git --git-dir="\$gitdir" --work-tree="\$tree" checkout -fq "\$branch"
  fi
  [ -n "\$run" ] && { echo "  Running: \$run"; (cd "\$tree" && eval "\$run"); }
}
REMOTE
}

# Execute deployments
SSH_OPTS=(-o ForwardAgent=yes "${ARGS[@]}")
RET=0
declare -a PIDS=()
((DRY)) && echo "Dry run mode"

for dest in "${!BATCHES[@]}"; do
  jobs=(${BATCHES[$dest]})
  if ((DRY)); then
    echo "Target: $dest"
    for job in "${jobs[@]}"; do
      repo=$(get "$job" REPO_URL)
      branch=$(get "$job" BRANCH)
      echo "  - Job '$job': $repo ($branch)"
    done
    continue
  fi
  (
    {
      remote_script
      for job in "${jobs[@]}"; do
        printf 'deploy %q %q %q %q %q %q\n' \
          "$job" "$(get "$job" REPO_URL)" "$(get "$job" BRANCH)" \
          "$(get "$job" DIR)" "$(get "$job" TREE)" "$(get "$job" RUN)"
      done
    } | ssh "${SSH_OPTS[@]}" "$dest" bash
  ) & PIDS+=($!)
done
for pid in "${PIDS[@]}"; do wait "$pid" || RET=1; done

# Generate aliases from job config
if ((RET == 0 && ${#SORTED[@]} > 0)); then
  echo ""
  for job in "${SORTED[@]}"; do
    dotdir=$(get "$job" DIR)
    tree=$(get "$job" TREE)
    [[ -z $tree ]] && tree="\$HOME"
    alias="cfg"; [[ $job != "default" ]] && alias="cfg-$job"
    echo -e "\033[32m  + alias $alias='/usr/bin/git --git-dir=\$HOME/$dotdir --work-tree=$tree'\033[0m"
  done
  echo ""
fi

if ((INTERACTIVE && !RET)); then
  echo "Connecting to $TARGET..."
  exec ssh -t "${SSH_OPTS[@]}" "$TARGET"
fi

exit $RET
